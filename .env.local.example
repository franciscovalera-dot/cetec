# Variables de entorno para Sanity
# Copia este archivo como .env.local y rellena los valores
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Token de escritura de Sanity (necesario para el panel de admin)
# Créalo en: https://www.sanity.io/manage → API → Tokens → Add API Token (Editor)
SANITY_API_WRITE_TOKEN=

# Contraseña de acceso al panel de administración (/admin)
ADMIN_PASSWORD=

# Google reCAPTCHA v2 ("No soy un robot")
# Crear un site en: https://www.google.com/recaptcha/admin
# - Type: reCAPTCHA v2 → "I'm not a robot" Checkbox
# - Domains: localhost + tu dominio de producción
# Si estas variables están vacías, el sistema permite los envíos (modo dev).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
