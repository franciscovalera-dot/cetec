# Variables de entorno para Sanity
# Copia este archivo como .env.local y rellena los valores
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Token de escritura de Sanity (necesario para el panel de admin)
# Créalo en: https://www.sanity.io/manage → API → Tokens → Add API Token (Editor)
SANITY_API_WRITE_TOKEN=

# Contraseña de acceso al panel de administración (/admin)
ADMIN_PASSWORD=

# Secret para firmar las cookies de sesión del admin (HMAC-SHA256).
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Si no se define, se deriva de ADMIN_PASSWORD (menos ideal, recomendado definirlo).
SESSION_SECRET=

# Google reCAPTCHA v2 ("No soy un robot")
# Crear un site en: https://www.google.com/recaptcha/admin
# - Type: reCAPTCHA v2 → "I'm not a robot" Checkbox
# - Domains: localhost + tu dominio de producción
# Si RECAPTCHA_SECRET_KEY está vacío, el sistema RECHAZA los envíos (fail-closed).
# Para desactivar reCAPTCHA solo en dev local, define RECAPTCHA_DISABLED=1.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
# RECAPTCHA_DISABLED=1   # SOLO dev local — nunca en producción
